#==============================================
# REQUIRED: set to your GCP and GitHub values
#==============================================

# GCP Configuration: dev environment
project                = "your-project-dev" # NOTE: USE A DIFFERENT PROJECT FOR EACH ENVIRONMENT
region                 = "us-central1"
google_cloud_location  = "global"
agent_name             = "your-agent-name"                     # NOTE: USE THE SAME AGENT NAME ACROSS ALL ENVIRONMENTS
terraform_state_bucket = "terraform-state-your-agent-name-dev" # NOTE: PRE-BOOTSTRAP CREATES A DIFFERENT BUCKET FOR EACH ENVIRONMENT

# Cross-project Artifact Registry docker image promotion
# - Set to null for dev bootstrap (images built in dev, no promotion)
# - Set to dev project values for stage bootstrap (promotion dev -> stage)
# - Set to stage values for prod bootstrap (promotion stage -> prod)
promotion_source_project                = null
promotion_source_artifact_registry_name = null

# GitHub Configuration
repository_owner = "your-github-username-or-org"
repository_name  = "your-agent-repository"


# ==============================================
# Recommended Defaults for the dev environment
# ==============================================

# OpenTelemetry Configuration
otel_instrumentation_genai_capture_message_content = "TRUE"

# Registry Cleanup Policies (dev: aggressive)
registry_cleanup_general_retention_days = 90   # All images expire after 90 days
registry_cleanup_keep_count             = 20   # Keep 20 most recent
registry_cleanup_pr_retention_days      = 30   # PR images expire after 30 days
