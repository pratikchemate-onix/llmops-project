### ===========================================
### Required Configuration
### ===========================================

### Google Cloud Vertex AI Model Authentication
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

### Unique agent identifier for cloud resources, logs, and traces
AGENT_NAME=agent-foundation

### OpenTelemetry message content capture (true/false) - https://opentelemetry.io/blog/2024/otel-generative-ai/#example-usage
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=TRUE


### ===========================================
### Cloud Resources (Recommended)
### Production-ready persistence for sessions, memory, and artifacts
### Get values from: GitHub Actions job summary or GCP Console after first deployment
### ===========================================

### Cloud SQL Auth Proxy (required for docker-compose)
# CLOUD_SQL_INSTANCE_CONNECTION_NAME=project-id:region:instance-name

### Session service (Cloud SQL via Auth Proxy)
# SESSION_SERVICE_URI=postgresql+asyncpg://SA_NAME@PROJECT.iam:@localhost:5432/agent_sessions

### Memory service (Agent Engine)
# MEMORY_SERVICE_URI=agentengine://projects/YOUR_PROJECT_ID/locations/YOUR_LOCATION/reasoningEngines/YOUR_ENGINE_ID

### Artifact storage via GCS bucket
# ARTIFACT_SERVICE_URI=gs://YOUR_BUCKET_NAME


### ===========================================
### Optional Agent App Runtime Configuration
### ===========================================

### Logging verbosity (default: INFO)
# LOG_LEVEL=DEBUG

### OpenTelemetry service namespace to group traces and logs (default: local)
# TELEMETRY_NAMESPACE=local-developer-unique-name

### Enable ADK web UI at http://localhost:8000 (default: FALSE)
# SERVE_WEB_INTERFACE=TRUE

### Enable ADK web to hot-reload agents on file changes - development only (default: FALSE)
# RELOAD_AGENTS=TRUE

### CORS allowed origins - JSON array string (default: ["http://localhost", "http://localhost:8000"])
# ALLOW_ORIGINS='["https://your-domain.com", "http://127.0.0.1:3000"]'

### Suppress ADK experimental feature warnings (default: FALSE)
# ADK_SUPPRESS_EXPERIMENTAL_FEATURE_WARNINGS=TRUE
